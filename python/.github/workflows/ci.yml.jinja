name: ci

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - {{ main_branch }}

jobs:
  pre-commit:
    uses: coatl-dev/workflows/.github/workflows/pre-commit.yml@462c6ebacbd14b67e9d583211eaa1f154229181e # v7.0.19
    with:
      skip-hooks: 'pylint'

  pylint:
    needs: pre-commit
    uses: coatl-dev/workflows/.github/workflows/pylint.yml@462c6ebacbd14b67e9d583211eaa1f154229181e # v7.0.19

  tox-package:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox-docker.yml@462c6ebacbd14b67e9d583211eaa1f154229181e # v7.0.19

  tox-stubs:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox.yml@462c6ebacbd14b67e9d583211eaa1f154229181e # v7.0.19
    with:
      python-versions: |
        3.9
        3.10
        3.11
        3.12
      working-directory: stubs
