name: ci

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - {{ main_branch }}

jobs:
  pre-commit:
    uses: coatl-dev/workflows/.github/workflows/pre-commit.yml@5973d22f237f120c397853de6dc9850a6bad78be # v7.0.15
    with:
      skip-hooks: 'pylint'

  pylint:
    needs: pre-commit
    uses: coatl-dev/workflows/.github/workflows/pylint.yml@5973d22f237f120c397853de6dc9850a6bad78be # v7.0.15

  tox-package:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox-docker.yml@5973d22f237f120c397853de6dc9850a6bad78be # v7.0.15

  tox-stubs:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox.yml@5973d22f237f120c397853de6dc9850a6bad78be # v7.0.15
    with:
      python-versions: |
        3.9
        3.10
        3.11
        3.12
      working-directory: stubs
