name: ci

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - {{ main_branch }}

jobs:
  pre-commit:
    uses: coatl-dev/workflows/.github/workflows/pre-commit.yml@61e70536453a45b98f2f3499227f063eb0a6ec86 # v7.0.21
    with:
      skip-hooks: 'pylint'

  pylint:
    needs: pre-commit
    uses: coatl-dev/workflows/.github/workflows/pylint.yml@61e70536453a45b98f2f3499227f063eb0a6ec86 # v7.0.21

  tox-package:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox-docker.yml@61e70536453a45b98f2f3499227f063eb0a6ec86 # v7.0.21

  tox-stubs:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox.yml@61e70536453a45b98f2f3499227f063eb0a6ec86 # v7.0.21
    with:
      python-versions: |
        3.9
        3.10
        3.11
        3.12
      working-directory: stubs
