name: ci

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - {{ main_branch }}

jobs:
  pre-commit:
    uses: coatl-dev/workflows/.github/workflows/pre-commit.yml@4efa3d1fee0878920d797eaf2754608f26cadb37 # v7.0.6
    with:
      skip-hooks: 'pylint'

  pylint:
    needs: pre-commit
    uses: coatl-dev/workflows/.github/workflows/pylint.yml@4efa3d1fee0878920d797eaf2754608f26cadb37 # v7.0.6

  tox-package:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox-docker.yml@4efa3d1fee0878920d797eaf2754608f26cadb37 # v7.0.6

  tox-stubs:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox.yml@4efa3d1fee0878920d797eaf2754608f26cadb37 # v7.0.6
    with:
      python-versions: |
        3.9
        3.10
        3.11
        3.12
      working-directory: stubs
