name: ci

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - {{ main_branch }}

jobs:
  pre-commit:
    uses: coatl-dev/workflows/.github/workflows/pre-commit.yml@3b10e4c46730151093c7ccbc52fd689a48b94726 # v7.0.16
    with:
      skip-hooks: 'pylint'

  pylint:
    needs: pre-commit
    uses: coatl-dev/workflows/.github/workflows/pylint.yml@3b10e4c46730151093c7ccbc52fd689a48b94726 # v7.0.16

  tox-package:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox-docker.yml@3b10e4c46730151093c7ccbc52fd689a48b94726 # v7.0.16

  tox-stubs:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox.yml@3b10e4c46730151093c7ccbc52fd689a48b94726 # v7.0.16
    with:
      python-versions: |
        3.9
        3.10
        3.11
        3.12
      working-directory: stubs
