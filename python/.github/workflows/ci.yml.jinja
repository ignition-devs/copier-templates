name: ci

on:
  workflow_dispatch:
  pull_request:
  push:
    branches:
      - {{ main_branch }}

jobs:
  pre-commit:
    uses: coatl-dev/workflows/.github/workflows/pre-commit.yml@e42dc6e92a7a5c8bfe6296759cf0a1c585a3df40 # v7.0.20
    with:
      skip-hooks: 'pylint'

  pylint:
    needs: pre-commit
    uses: coatl-dev/workflows/.github/workflows/pylint.yml@e42dc6e92a7a5c8bfe6296759cf0a1c585a3df40 # v7.0.20

  tox-package:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox-docker.yml@e42dc6e92a7a5c8bfe6296759cf0a1c585a3df40 # v7.0.20

  tox-stubs:
    if: ${% raw %}{{ github.event_name == 'pull_request' }}{% endraw %}
    uses: coatl-dev/workflows/.github/workflows/tox.yml@e42dc6e92a7a5c8bfe6296759cf0a1c585a3df40 # v7.0.20
    with:
      python-versions: |
        3.9
        3.10
        3.11
        3.12
      working-directory: stubs
