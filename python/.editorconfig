# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true

[*.{json}]
indent_size = 2
insert_final_newline = false

[*.{md,toml,yaml,yml}]
indent_size = 2
insert_final_newline = true

[*.{ini,py,pyi}]
indent_size = 4
insert_final_newline = true
