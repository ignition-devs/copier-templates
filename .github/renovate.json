{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "pinDigests": true,
  "semanticCommits": "enabled",
  "semanticCommitType": "refactor",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.github/workflows/.+\\.jinja$"
      ],
      "matchStrings": [
        "uses:\\s+(?<depName>[a-zA-Z0-9_.-]+/[a-zA-Z0-9_.-]+)@(?<currentDigest>[a-f0-9]{40})\\s*#\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver"
    }
  ]
}