{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard",
    ":semanticCommitTypeAll(refactor)"
  ],
  "ignorePaths": [
    ".github/workflows/**"
  ],
  "github-actions": {
    "managerFilePatterns": [
      "/(?:^|/)(?:ignition|jython|python)/\\.github/workflows/.+\\.(?:ya?ml|ya?ml\\.jinja)$/"
    ]
  }
}