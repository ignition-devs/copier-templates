{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard",
    ":semanticCommitTypeAll(refactor)"
  ],
  "github-actions": {
    "managerFilePatterns": [
      "/(?:ignition|jython|python)/\\.github/workflows/.+\\.ya?ml(?:.jinja)?$//"
    ]
  },
  "ignorePaths": [
    ".github/workflows/**"
  ]
}